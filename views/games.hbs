{{! Adapted from CS 340 bsg_people example web application}}
<h1>Games</h1>

{{! READ table }}
<table>
    <thead>
        {{! For the table header row, we print the DB attribute names }}
        <tr>
            <th>Game ID</th>
            <th>Game Title</th>
            <th>Game Developer</th>
            <th>Release Year</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        {{! For each row, print the id, fname, lname, homeworld and age }}
        {{#each games}}
        <tr>
            <td>{{this.gameID}}</td>
            <td>{{this.title}}</td>
            <td>{{this.developer}}</td>
            <td>{{this.releaseYear}}</td>

            {{! DELETE form }}
            <form id='delete_game_form' method="POST" action="/games/delete">
                <input type='hidden' name='delete_game_ID' value='{{this.gameID}}' />
                <td>
                    <button type='submit'>
                        Delete
                    </button>
                </td>
            </form>
        </tr>
        {{/each}}
    </tbody>
</table>

{{#if error}}
    <p style="color: red; margin-left: 32px;">{{error}}</p>
{{/if}}

{{! CREATE form }}
<h2>Create a Game</h2>
<form class='cuForm' id='create_game_form' method="POST" action="/games/add">
    <label for='create_game_title'>Game Title: </label>
    <input type='text' name='create_game_title' id='create_game_title' required />

    <label for='create_game_developer'>Game Developer: </label>
    <input type='text' name='create_game_developer' id='create_game_developer' required />

    <label for='create_game_releaseYear'>Release Year: </label>
    <input type='number' name='create_game_releaseYear' id='create_game_releaseYear' min='1900' max='2026' required />

    <input type='submit' />
</form>

{{! UPDATE form }}
<h2>Update a Game</h2>
<form class='cuForm' id='update_game_form' method="POST" action="/games/update">
    <label for='update_game_id'>Game to Update: </label>
    <select name='update_game_id' id='update_game_id' required>
        <option value='' disabled selected>Select a Game</option>
        {{#each games}}
        <option value='{{this.gameID}}' data-title='{{this.title}}' data-developer='{{this.developer}}' data-releaseyear='{{this.releaseYear}}'>
            {{this.gameID}}
            -
            {{this.title}}
        </option>
        {{/each}}
    </select>

    <label for='update_game_title'>Game Title: </label>
    <input type='text' name='update_game_title' id='update_game_title' required>

    <label for='update_game_manufacturer'>Game Developer: </label>
    <input type='text' name='update_game_manufacturer' id='update_game_manufacturer' required />

    <label for='update_game_releaseYear'>Release Year: </label>
    <input type='number' name='update_game_releaseYear' id='update_game_releaseYear' min='1900' max='2026' required />

    <input type='submit' />
</form>
<script>
    document.getElementById('update_game_id').addEventListener('change', function(){
        const selectedOption = this.options[this.selectedIndex];
        document.getElementById('update_game_title').value = selectedOption.dataset.title;
        document.getElementById('update_game_manufacturer').value = selectedOption.dataset.developer;
        document.getElementById('update_game_releaseYear').value = selectedOption.dataset.releaseyear;
    });
</script>
